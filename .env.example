# VulnScout unified environment file.
# Copy to .env and fill in what you need — not every variable is required
# for every piece. See the comments below each section.

# --- core/ (Strix) ---
# LLM provider key. LLM_API_KEY is the generic alias; OPENAI_API_KEY also works.
LLM_API_KEY=
# Model identifier Strix should drive, e.g. anthropic/claude-opus-4-8
STRIX_LLM=

# --- submit/ (h1-brain) ---
# HackerOne account credentials — required to run the MCP server.
H1_USERNAME=
H1_API_TOKEN=

# --- recon/ (mailrecon) ---
# No credentials required — passive by default. Active checks are gated
# behind a --scope authorization file, not an env var. See recon/README.md.
